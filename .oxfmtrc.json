{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "none",
  "arrowParens": "avoid",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "pnpm-lock.yaml",
    "/.examples-temp",
    "/tests/.fixtures-temp"
  ]
}
